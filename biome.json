{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "root": true,
  "formatter": {
    "enabled": true,
    "indentStyle": "tab",
    "lineWidth": 100
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": {
          "level": "error",
          "options": {
            "style": "separatedType"
          }
        },
        "useNodejsImportProtocol": "error",
        "useConst": "error",
        "noRestrictedTypes": {
          "level": "error",
          "options": {
            "types": {
              "Buffer": {
                "message": "Use Uint8Array instead of Buffer for cross-runtime compatibility.",
                "use": "Uint8Array"
              }
            }
          }
        }
      },
      "suspicious": {
        "noImplicitAnyLet": "error",
        "noDuplicateObjectKeys": "error",
        "noTsIgnore": "error",
        "noDebugger": "error",
        "noExplicitAny": "error",
        "noConsole": "warn"
      },
      "performance": {
        "noDelete": "error"
      },
      "complexity": {
        "useDateNow": "error",
        "noUselessSwitchCase": "error",
        "noUselessTypeConstraint": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "nursery": {
        "noMisusedPromises": "error",
        "noFloatingPromises": "error"
      },
      "security": {
        "noDangerouslySetInnerHtml": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.json"],
      "formatter": {
        "indentStyle": "space",
        "indentWidth": 2
      }
    },
    {
      "includes": ["**/*.test.*", "**/*.spec.*", "**/test/**", "**/__tests__/**", "**/examples/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off"
          },
          "style": {
            "noRestrictedTypes": "off",
            "noNonNullAssertion": "off"
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/coverage",
      "!**/build",
      "!**/.turbo",
      "!**/.cache",
      "!**/docs-local/repo-ref",
      "!docs",
      "!**/.next",
      "!sdks/python",
      "!examples/nextjs-demo"
    ]
  }
}
