{
  "name": "@kavachos/plugin-discovery",
  "version": "0.0.3",
  "description": "A2A agent capability card discovery plugin for KavachOS",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "kavachos",
    "discovery",
    "a2a",
    "agent",
    "capability",
    "mcp"
  ],
  "author": "KavachOS <hello@kavachos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavachos/kavachos.git",
    "directory": "packages/plugins/discovery"
  },
  "dependencies": {
    "drizzle-orm": "^0.41.0"
  },
  "peerDependencies": {
    "kavachos": "workspace:*"
  },
  "devDependencies": {
    "kavachos": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  }
}
