{
  "name": "@kavachos/sveltekit",
  "version": "0.0.1",
  "description": "SvelteKit adapter for KavachOS - exposes agent auth as HTTP REST endpoints",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "kavachos",
    "sveltekit",
    "auth",
    "agent",
    "mcp"
  ],
  "author": "KavachOS <hello@kavachos.com>",
  "license": "MIT",
  "peerDependencies": {
    "kavachos": "workspace:*",
    "@sveltejs/kit": ">=2.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "kavachos": "workspace:*",
    "@sveltejs/kit": "^2.16.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "zod": "^3.24.0"
  }
}
