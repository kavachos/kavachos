{
  "name": "@kavachos/nestjs",
  "version": "0.0.3",
  "description": "NestJS adapter for KavachOS",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "kavachos",
    "nestjs",
    "auth",
    "agent",
    "mcp"
  ],
  "license": "MIT",
  "author": "KavachOS <hello@kavachos.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavachos/kavachos.git",
    "directory": "packages/adapters/nestjs"
  },
  "peerDependencies": {
    "kavachos": "workspace:*",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "kavachos": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@types/express": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "zod": "^3.24.0"
  }
}
