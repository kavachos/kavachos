{
  "name": "@kavachos/test-utils",
  "version": "0.1.0",
  "description": "Test utilities for KavachOS — mock providers, factories, and assertions for auth test suites",
  "license": "MIT",
  "author": "KavachOS <hello@kavachos.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavachos/kavachos.git",
    "directory": "packages/test-utils"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@kavachos/react": ">=0.0.1",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@kavachos/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kavachos/react": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
