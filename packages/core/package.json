{
  "name": "kavachos",
  "version": "0.1.5",
  "description": "The auth OS for AI agents - identity, permissions, delegation, and audit for the agentic era",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "default": "./dist/agent/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "default": "./dist/auth/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "default": "./dist/mcp/index.js"
    },
    "./permission": {
      "types": "./dist/permission/index.d.ts",
      "import": "./dist/permission/index.js",
      "default": "./dist/permission/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js",
      "default": "./dist/audit/index.js"
    },
    "./a2a": {
      "types": "./dist/a2a/index.d.ts",
      "import": "./dist/a2a/index.js",
      "default": "./dist/a2a/index.js"
    },
    "./vc": {
      "types": "./dist/vc/index.d.ts",
      "import": "./dist/vc/index.js",
      "default": "./dist/vc/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js",
      "default": "./dist/crypto/index.js"
    },
    "./redirect": {
      "types": "./dist/redirect/index.d.ts",
      "import": "./dist/redirect/index.js",
      "default": "./dist/redirect/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "auth",
    "agent",
    "mcp",
    "ai",
    "identity",
    "authentication",
    "authorization",
    "oauth",
    "audit",
    "permissions"
  ],
  "author": "KavachOS <hello@kavachos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavachos/kavachos.git",
    "directory": "packages/core"
  },
  "homepage": "https://kavachos.com",
  "dependencies": {
    "drizzle-orm": "^0.41.0",
    "jose": "^6.0.0",
    "sql.js": "^1.14.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "^3.2.4",
    "better-sqlite3": "^11.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@libsql/client": ">=0.6.0",
    "better-sqlite3": ">=9.0.0",
    "mysql2": ">=3.0.0",
    "pg": ">=8.0.0",
    "sql.js": ">=1.10.0"
  },
  "peerDependenciesMeta": {
    "sql.js": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "@libsql/client": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  }
}
