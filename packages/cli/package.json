{
  "name": "@kavachos/cli",
  "version": "0.0.5",
  "description": "KavachOS CLI - setup wizard, dashboard launcher, and development tools",
  "type": "module",
  "bin": {
    "kavachos": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kavachos": "workspace:*",
    "@kavachos/hono": "workspace:*",
    "hono": "^4.0.0",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "kavachos",
    "auth",
    "agent",
    "cli"
  ],
  "author": "KavachOS <hello@kavachos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavachos/kavachos.git",
    "directory": "packages/cli"
  }
}
