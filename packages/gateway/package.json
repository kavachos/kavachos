{
  "name": "@kavachos/gateway",
  "version": "0.0.5",
  "description": "Standalone auth proxy for KavachOS - enforces auth, authorization, and audit in front of any API or MCP server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kavachos-gateway": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "kavachos",
    "gateway",
    "proxy",
    "auth",
    "agent",
    "mcp",
    "middleware"
  ],
  "author": "KavachOS <hello@kavachos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavachos/kavachos.git",
    "directory": "packages/gateway"
  },
  "dependencies": {
    "micromatch": "^4.0.8"
  },
  "peerDependencies": {
    "kavachos": "workspace:*",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "kavachos": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/micromatch": "^4.0.9",
    "better-sqlite3": "^11.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
